<article class="detail">
  <% if @post.images.attached? %>
    <%= image_tag @post.images.first.variant(:large), alt: @post.title, class: "detail-photo" %>
  <% end %>
  <div class="detail-body">
    <p class="eyebrow">管理画面</p>
    <h1><%= @post.title %></h1>
    <p class="warning">撮影禁止場所、私有地、人物写り込み、迷惑行為につながる内容がないか確認してください。</p>
    <dl class="meta-list">
      <div>
        <dt>ステータス</dt>
        <dd><%= @post.status %></dd>
      </div>
      <div>
        <dt>投稿者</dt>
        <dd><%= @post.user.name %></dd>
      </div>
      <div>
        <dt>場所</dt>
        <dd><%= @post.area %> / <%= @post.address %></dd>
      </div>
    </dl>
    <p><%= @post.description %></p>
    <div class="action-row">
      <%= button_to "公開する", publish_admin_post_path(@post), method: :patch, class: "primary-button" %>
      <%= button_to "非公開にする", hide_admin_post_path(@post), method: :patch, class: "secondary-button danger" %>
    </div>
  </div>
</article>
