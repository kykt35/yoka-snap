<section class="profile">
  <% if current_user.avatar.attached? %>
    <%= image_tag current_user.avatar.variant(:avatar), alt: current_user.name, class: "avatar" %>
  <% end %>
  <div>
    <p class="eyebrow">マイページ</p>
    <h1><%= current_user.name %></h1>
  </div>
</section>

<section class="section-heading">
  <h2>自分の投稿</h2>
  <%= link_to "投稿する", new_post_path, class: "primary-link" %>
</section>
<div class="post-grid">
  <%= render partial: "posts/post_card", collection: @posts, as: :post %>
</div>

<section class="section-heading">
  <h2>行きたい</h2>
  <%= link_to "一覧を見る", want_to_go_posts_path, class: "primary-link" %>
</section>
<div class="post-grid">
  <%= render partial: "posts/post_card", collection: @want_to_go_posts, as: :post %>
</div>
