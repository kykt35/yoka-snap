<section class="mx-auto max-w-md rounded-lg border border-yoka-line bg-yoka-surface p-[18px]">
  <h1 class="text-[clamp(2rem,8vw,3rem)] font-extrabold leading-[1.08] text-yoka-green-dark">新しいパスワード</h1>

  <%= tag.div(flash[:alert], class: "mt-4 rounded-lg bg-[#fff0ec] px-3.5 py-3 text-[#7c2f20]") if flash[:alert] %>

  <%= form_with url: password_path(params[:token]), method: :put, class: "mt-5 grid gap-2.5" do |form| %>
    <%= form.label :password, "新しいパスワード", class: "font-extrabold" %>
    <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "新しいパスワード", maxlength: 72, class: "min-h-[42px] w-full rounded-lg border border-yoka-line px-2.5 py-2.5" %>
    <%= form.label :password_confirmation, "新しいパスワード（確認）", class: "font-extrabold" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "もう一度入力", maxlength: 72, class: "min-h-[42px] w-full rounded-lg border border-yoka-line px-2.5 py-2.5" %>
    <%= form.submit "保存する", class: "primary-button" %>
  <% end %>
</section>
