<% saved = current_user&.reactions&.exists?(post: post, reaction_type: "want_to_go") %>
<% if current_user %>
  <% if saved %>
    <%= button_to "行きたい済み #{post.want_to_go_count}", post_reaction_path(post, reaction_type: :want_to_go), method: :delete, class: "secondary-button" %>
  <% else %>
    <%= button_to "行きたい #{post.want_to_go_count}", post_reactions_path(post, reaction_type: :want_to_go), method: :post, class: "primary-button" %>
  <% end %>
<% else %>
  <%= link_to "行きたい #{post.want_to_go_count}", new_session_path, class: "secondary-button" %>
<% end %>
