<section class="mx-auto max-w-md rounded-lg border border-yoka-line bg-yoka-surface p-[18px]">
  <p class="mb-2 font-extrabold text-yoka-accent">ログイン</p>
  <h1 class="text-[clamp(2rem,8vw,3rem)] font-extrabold leading-[1.08] text-yoka-green-dark">よかスナップへログイン</h1>

  <%= tag.div(flash[:alert], class: "mt-4 rounded-lg bg-[#fff0ec] px-3.5 py-3 text-[#7c2f20]") if flash[:alert] %>
  <%= tag.div(flash[:notice], class: "mt-4 rounded-lg bg-[#eaf4ee] px-3.5 py-3 text-yoka-green-dark") if flash[:notice] %>

  <%= form_with url: session_path, class: "mt-5 grid gap-2.5" do |form| %>
    <%= form.label :email_address, "メールアドレス", class: "font-extrabold" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "mail@example.com", value: params[:email_address], class: "min-h-[42px] w-full rounded-lg border border-yoka-line px-2.5 py-2.5" %>
    <%= form.label :password, "パスワード", class: "font-extrabold" %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "パスワード", maxlength: 72, class: "min-h-[42px] w-full rounded-lg border border-yoka-line px-2.5 py-2.5" %>
    <%= form.submit "ログイン", class: "primary-button" %>
  <% end %>

  <%= link_to "パスワードを忘れた方", new_password_path, class: "mt-4 inline-flex font-extrabold text-yoka-accent" %>
</section>
